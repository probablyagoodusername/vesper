---
import '../styles/globals.css'

interface Props {
  title?: string
}

const { title = 'Vesper — Rest in the Word' } = Astro.props
const currentPath = Astro.url.pathname
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <meta name="theme-color" content="#f8f4f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0807" media="(prefers-color-scheme: dark)" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="description" content="Bible meditation, guided prayer, breathing exercises, and sleep." />
    <link rel="manifest" href={`${base}/manifest.json`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,500;0,7..72,600;0,7..72,700;1,7..72,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Restore theme — runs on initial load AND after every View Transition swap
      function applyVesperTheme() {
        var s = localStorage.getItem('vesper-theme') || 'auto';
        var dark = s === 'dark' || (s === 'auto' && (new Date().getHours() >= 20 || new Date().getHours() < 7));
        if (dark) document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
        // Update theme-color meta to match
        var metas = document.querySelectorAll('meta[name="theme-color"]');
        metas.forEach(function(m) { m.setAttribute('content', dark ? '#0c0807' : '#f8f4f2'); });
      }
      function applyVesperLocale() {
        var locale = localStorage.getItem('vesper-locale') || 'en';
        document.querySelectorAll('[data-en][data-fr]').forEach(function(el) {
          el.textContent = el.getAttribute('data-' + locale) || el.getAttribute('data-en');
        });
      }
      applyVesperTheme();
      applyVesperLocale();
      document.addEventListener('astro:after-swap', function() {
        applyVesperTheme();
        applyVesperLocale();
        // Force React islands to re-read locale after View Transition swap
        window.dispatchEvent(new Event('vesper-locale-changed'));
      });
      // Re-translate nav when locale changes from Settings page
      window.addEventListener('vesper-locale-changed', applyVesperLocale);
    </script>
    <style is:global>
      :root {
        --font-serif: 'Literata', Georgia, 'Times New Roman', serif;
      }
    </style>
  </head>
  <body class="bg-[var(--bg)] text-[var(--text)]">
    <div id="vesper-content" class="min-h-dvh pb-20">
      <slot />
    </div>

    <!-- Stagger animation — vanilla Motion JS, no React hydration conflict -->
    <script>
      import { animate, stagger } from "motion";

      // Wait for DOM + React hydration, then animate
      function runStagger() {
        const items = document.querySelectorAll(".stagger-item");
        if (items.length === 0) return;

        animate(
          items,
          { opacity: [0, 1], y: [16, 0] },
          {
            duration: 0.5,
            delay: stagger(0.05, { startDelay: 0.1 }),
            easing: [0.16, 1, 0.3, 1],
          }
        );
      }

      // Run after a small delay to let React hydrate
      if (document.readyState === "complete") {
        setTimeout(runStagger, 50);
      } else {
        window.addEventListener("load", () => setTimeout(runStagger, 50));
      }
    </script>

    <!-- Persistent audio player -->
    <div id="audio-player"></div>

    <nav class="fixed bottom-0 left-0 right-0 z-50 flex justify-center safe-bottom" style="padding-bottom: env(safe-area-inset-bottom, 8px)">
      <div class="mx-4 mb-2 flex w-full max-w-sm items-center justify-around rounded-full liquid-glass py-1.5">
        {[
          { href: `${base}/home`, en: 'Home', fr: 'Accueil',
