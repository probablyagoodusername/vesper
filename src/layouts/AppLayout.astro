---
// import { ClientRouter } from 'astro:transitions'
import '../styles/globals.css'

interface Props {
  title?: string
}

const { title = 'Vesper — Rest in the Word' } = Astro.props
const currentPath = Astro.url.pathname
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <meta name="theme-color" content="#1e1a17" />
    <meta name="description" content="Bible meditation, guided prayer, breathing exercises, and sleep." />
    <link rel="manifest" href={`${base}/manifest.json`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,500;0,7..72,600;0,7..72,700;1,7..72,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      // Restore theme — runs on initial load AND after every View Transition swap
      function applyVesperTheme() {
        var s = localStorage.getItem('vesper-theme') || 'auto';
        var dark = s === 'dark' || (s === 'auto' && (new Date().getHours() >= 20 || new Date().getHours() < 7));
        if (dark) document.documentElement.classList.add('dark');
        else document.documentElement.classList.remove('dark');
      }
      function applyVesperLocale() {
        var locale = localStorage.getItem('vesper-locale') || 'en';
        document.querySelectorAll('[data-en][data-fr]').forEach(function(el) {
          el.textContent = el.getAttribute('data-' + locale) || el.getAttribute('data-en');
        });
      }
      applyVesperTheme();
      applyVesperLocale();
      document.addEventListener('astro:after-swap', function() {
        applyVesperTheme();
        applyVesperLocale();
        // Force React islands to re-read locale after View Transition swap
        window.dispatchEvent(new Event('vesper-locale-changed'));
      });
      // Re-translate nav when locale changes from Settings page
      window.addEventListener('vesper-locale-changed', applyVesperLocale);
    </script>
    <!-- ClientRouter removed — investigating proper transition solution -->
    <style is:global>
      :root {
        --font-serif: 'Literata', Georgia, 'Times New Roman', serif;
      }
    </style>
  </head>
  <body class="bg-[var(--bg)] text-[var(--text)]">
    <div class="min-h-dvh pb-20 pt-6">
      <!-- Top bar — back chevron + Vesper wordmark -->
      <header class="fixed top-0 left-0 right-0 z-50 flex h-12 items-center justify-between border-b border-[var(--border)]/50 bg-[var(--bg)]/95 px-4 backdrop-blur-sm">
        <button
          onclick="if (window.history.length > 1) { window.history.back() } else { window.location.href = base + '/home' }"
          class="flex h-8 w-8 items-center justify-center text-[var(--accent)] transition-opacity hover:opacity-70"
          aria-label="Back"
          id="vesper-back-btn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
          </svg>
        </button>
        <a href={`${base}/home`} aria-label="Vesper home">
          <svg class="vesper-nav-wm-dark" width="68" height="16" viewBox="0 0 120 28" xmlns="http://www.w3.org/2000/svg">
            <text font-family="Literata, Georgia, serif" font-weight="700" font-size="26" fill="#81b19b" x="0" y="22">V</text>
            <text font-family="Literata, Georgia, serif" font-weight="300" font-size="26" fill="#e2ddda" x="19" y="22">esper</text>
          </svg>
          <svg class="vesper-nav-wm-light" width="68" height="16" viewBox="0 0 120 28" xmlns="http://www.w3.org/2000/svg">
            <text font-family="Literata, Georgia, serif" font-weight="700" font-size="26" fill="#3d6f5a" x="0" y="22">V</text>
            <text font-family="Literata, Georgia, serif" font-weight="300" font-size="26" fill="#201914" x="19" y="22">esper</text>
          </svg>
        </a>
      </header>
      <slot />
    </div>
    <script is:inline define:vars={{ base }}>
      // Show back button only on sub-pages (bible, meditation sessions)
      // Hide on tab-level pages (home, breathe, meditate, sleep, settings)
      var tabPaths = ['/home', '/breathe', '/meditate', '/sleep', '/settings', '/']
      document.addEventListener('astro:page-load', function() {
        var btn = document.getElementById('vesper-back-btn')
        if (!btn) return
        var path = window.location.pathname.replace(/\/$/, '') || '/'
        var isTab = tabPaths.some(function(t) { return path === base + t || path === t })
        btn.style.visibility = isTab ? 'hidden' : 'visible'
      })
    </script>

    <!-- Persistent audio player — survives navigation -->
    <div id="audio-player"></div>

    <nav class="fixed bottom-0 left-0 right-0 z-50 border-t border-[var(--border)] bg-[var(--bg)]/95 backdrop-blur-sm safe-bottom">
      <div class="mx-auto flex max-w-lg items-center justify-around">
        {[
          { href: `${base}/home`, en: 'Home', fr: 'Accueil', d: 'M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z' },
          { href: `${base}/breathe`, en: 'Breathe', fr: 'Respirer', d: 'M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2M9.6 4.6A2 2 0 1 1 11 8H2M12.6 19.4A2 2 0 1 0 14 16H2' },
          { href: `${base}/meditate`, en: 'Meditate', fr: 'Méditer', d: 'M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275z' },
          { href: `${base}/sleep`, en: 'Sleep', fr: 'Dormir', d: 'M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z' },
          { href: `${base}/settings`, en: 'Settings', fr: 'Réglages', d: 'M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z' },
        ].map(({ href, en, fr, d }) => {
          const isActive = currentPath.startsWith(href)
          return (
            <a
              href={href}
              class={`flex flex-col items-center gap-0.5 px-3 py-2.5 text-xs transition-colors ${isActive ? 'text-[var(--accent)]' : 'text-[var(--muted)]'}`}
            >
              <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isActive ? '2' : '1.5'} stroke-linecap="round" stroke-linejoin="round">
                <path d={d} />
              </svg>
              <span data-en={en} data-fr={fr}>{en}</span>
            </a>
          )
        })}
      </div>
    </nav>
  </body>
</html>
