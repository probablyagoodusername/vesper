---
import AppLayout from '../../layouts/AppLayout.astro'
import { SearchClient } from '../../components/SearchClient'
import { readFileSync } from 'fs'
import { resolve } from 'path'

const BIBLE_DIR = resolve(process.cwd(), 'src/content/bible')
const booksIndex = JSON.parse(readFileSync(resolve(BIBLE_DIR, '_books.json'), 'utf-8'))
---

<AppLayout title="Search — Vesper">
  <SearchClient client:only="react" books={booksIndex} />
</AppLayout>
