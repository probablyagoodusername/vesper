---
import AppLayout from '../layouts/AppLayout.astro'
import { HomeClient } from '../components/HomeClient'

// Load all meditation JSON files
const meditationFiles = import.meta.glob('../content/meditations/*.json', { eager: true })
const allMeditations = Object.values(meditationFiles)
  .map((m: any) => m.default ?? m)
  .map(({ slug, titleEn, titleFr, descEn, descFr, durationMin, audioPathEn, isSleep, category, sortOrder }: any) => ({
    slug, titleEn, titleFr, descEn, descFr, durationMin, audioPathEn, isSleep, category, sortOrder,
  }))
---

<AppLayout title="Vesper — Rest in the Word">
  <HomeClient
    client:idle
    allMeditations={allMeditations}
  />
</AppLayout>
