---
import AppLayout from '../../layouts/AppLayout.astro'
import { MeditationPlayer } from '../../components/MeditationPlayer'

const meditationFiles = import.meta.glob('../../content/meditations/*.json', { eager: true })
const allMeditations = Object.values(meditationFiles).map((m: any) => m.default ?? m)

export function getStaticPaths() {
  const meditationFiles = import.meta.glob('../../content/meditations/*.json', { eager: true })
  const all = Object.values(meditationFiles).map((m: any) => m.default ?? m)
  const sleepMeditations = all.filter((m: any) => m.isSleep)
  return sleepMeditations.map((m: any) => ({
    params: { slug: m.slug },
  }))
}

const { slug } = Astro.params
const meditation = allMeditations.find((m: any) => m.slug === slug)

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

if (!meditation) {
  return Astro.redirect(`${base}/sleep`)
}
---

<AppLayout title={`${meditation.titleEn} — Vesper`}>
  <MeditationPlayer client:load meditation={meditation} backHref={`${base}/sleep`} />
</AppLayout>
