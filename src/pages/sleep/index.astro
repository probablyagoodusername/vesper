---
import AppLayout from '../../layouts/AppLayout.astro'
import { SleepClient } from '../../components/SleepClient'

const meditationFiles = import.meta.glob('../../content/meditations/*.json', { eager: true })
const sleepMeditations = Object.values(meditationFiles)
  .map((m: any) => m.default ?? m)
  .filter((m: any) => m.isSleep)
  .sort((a: any, b: any) => a.sortOrder - b.sortOrder)
  .map(({ slug, titleEn, titleFr, descEn, descFr, durationMin, audioPathEn, isSleep, category, sortOrder }: any) => ({
    slug, titleEn, titleFr, descEn, descFr, durationMin, audioPathEn, isSleep, category, sortOrder,
  }))
---

<AppLayout title="Sleep — Vesper">
  <SleepClient client:only="react" meditations={sleepMeditations} />
</AppLayout>
